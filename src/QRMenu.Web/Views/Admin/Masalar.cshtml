@model List<QRMenu.Web.ViewModels.QrKodViewModel>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Masalar";
    ViewData["ActivePage"] = "Masalar";
    ViewData["PageTitle"] = "Masalar Yönetimi";
}

@section Styles {
    <link href="~/css/admin-masalar.css" rel="stylesheet" />
}

<!-- Başlık + Yeni Masa Butonu -->
<div class="content-header">
    <h5><i class="bi bi-grid-3x3-gap"></i> Masa Listesi</h5>
    <button class="btn btn-yeni-masa" data-bs-toggle="modal" data-bs-target="#masaEkleModal">
        <i class="bi bi-plus-lg"></i> Yeni Masa Ekle
    </button>
</div>

<div id="mesaj"></div>

<!-- Masa Kartları -->
<div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3" id="masaGrid">
    @foreach (var item in Model)
    {
        <div class="col" id="col-@item.MasaNo">
            <div class="masa-card">
                <div class="masa-card-body">
                    <div class="masa-no">Masa @item.MasaNo</div>
                    <div class="masa-bolge"><i class="bi bi-geo-alt"></i> Bölge: Salon</div>
                    <span class="masa-durum durum-bos">
                        <i class="bi bi-circle-fill" style="font-size:0.5rem;"></i> Boş
                    </span>

                    <div class="qr-area">
                        <div class="qr-placeholder-sm" id="placeholder-@item.MasaNo"
                             style="@(string.IsNullOrEmpty(item.QrUrl) ? "" : "display:none")">
                            <span>QR Yok</span>
                        </div>
                        <img class="qr-img-sm" id="qr-img-@item.MasaNo" alt="QR"
                             style="@(string.IsNullOrEmpty(item.QrUrl) ? "display:none" : "")" />
                    </div>

                    @if (!string.IsNullOrEmpty(item.QrUrl))
                    {
                        <span class="badge bg-success" style="font-size:0.65rem;" id="qrbadge-@item.MasaNo">QR Aktif</span>
                    }
                    else
                    {
                        <button class="btn btn-sm btn-outline-primary" onclick="olustur(@item.MasaNo)" id="qrolustur-@item.MasaNo" style="font-size:0.75rem;">
                            <i class="bi bi-qr-code"></i> QR Oluştur
                        </button>
                    }
                </div>
                <div class="masa-card-footer">
                    <button class="footer-btn btn-qr @(string.IsNullOrEmpty(item.QrUrl) ? "d-none" : "")"
                            id="indir-@item.MasaNo" onclick="indir(@item.MasaNo)">
                        <i class="bi bi-download"></i> QR İndir
                    </button>
                    <button class="footer-btn btn-edit" onclick="alert('Düzenleme ileride eklenecek')">
                        <i class="bi bi-pencil"></i> Düzenle
                    </button>
                    <button class="footer-btn btn-delete" onclick="masaSil(@item.MasaNo)">
                        <i class="bi bi-trash"></i> Sil
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<!-- Yeni Masa Ekle Modal -->
<div class="modal fade" id="masaEkleModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h6 class="modal-title"><i class="bi bi-plus-circle"></i> Yeni Masa Ekle</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <label class="form-label">Masa Numarası</label>
                <input type="number" id="yeniMasaNo" class="form-control" placeholder="Ör: 7" min="1" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn btn-success btn-sm" onclick="masaOlustur()">
                    <i class="bi bi-check-lg"></i> Oluştur
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    var qrData = {};

    function mesaj(text, tip) {
        document.getElementById('mesaj').innerHTML = '<div class="alert alert-' + tip + ' py-2 mb-3" style="font-size:0.85rem;">' + text + '</div>';
        setTimeout(function() { document.getElementById('mesaj').innerHTML = ''; }, 3000);
    }

    function masaOlustur() {
        var no = document.getElementById('yeniMasaNo').value;
        if (!no || no < 1) { mesaj('Geçerli bir masa numarası girin', 'danger'); return; }
        fetch('/admin/masa-olustur/' + no).then(r => r.json()).then(data => {
            if (data.success) {
                bootstrap.Modal.getInstance(document.getElementById('masaEkleModal')).hide();
                mesaj('Masa ' + no + ' başarıyla oluşturuldu', 'success');
                setTimeout(() => location.reload(), 500);
            } else {
                mesaj(data.message, 'warning');
            }
        });
    }

    function masaSil(masaNo) {
        if (!confirm('Masa ' + masaNo + ' silinsin mi?')) return;
        fetch('/admin/masa-sil/' + masaNo).then(r => r.json()).then(data => {
            if (data.success) {
                var col = document.getElementById('col-' + masaNo);
                if (col) { col.style.transition = 'opacity 0.3s'; col.style.opacity = '0'; setTimeout(() => col.remove(), 300); }
                mesaj(data.message || 'Masa ' + masaNo + ' silindi', 'success');
            } else { mesaj(data.message, 'danger'); }
        });
    }

    function olustur(masaNo) {
        fetch('/admin/qr-olustur/' + masaNo).then(r => r.json()).then(data => {
            if (data.success) {
                qrData[masaNo] = data.qrBase64;
                var img = document.getElementById('qr-img-' + masaNo);
                img.src = 'data:image/png;base64,' + data.qrBase64;
                img.style.display = 'block';
                document.getElementById('placeholder-' + masaNo).style.display = 'none';

                var btn = document.getElementById('qrolustur-' + masaNo);
                if (btn) { btn.outerHTML = '<span class="badge bg-success" style="font-size:0.65rem;" id="qrbadge-' + masaNo + '">QR Aktif</span>'; }

                document.getElementById('indir-' + masaNo).classList.remove('d-none');
            }
        });
    }

    function indir(masaNo) {
        var b = qrData[masaNo];
        if (!b) { alert('Önce QR oluşturun'); return; }
        var a = document.createElement('a');
        a.href = 'data:image/png;base64,' + b;
        a.download = 'Masa_' + masaNo + '_QR.png';
        document.body.appendChild(a); a.click(); document.body.removeChild(a);
    }

    document.addEventListener('DOMContentLoaded', function() {
        @foreach (var item in Model)
        {
            if (!string.IsNullOrEmpty(item.QrUrl))
            {
                <text>olustur(@item.MasaNo);</text>
            }
        }
    });
</script>
}
